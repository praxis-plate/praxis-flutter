# Codium AI Smart Reader - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Google Gemini API Key
# Get your free API key from: https://makersuite.google.com/app/apikey
# Free tier: 60 requests per minute
GEMINI_API_KEY=your_gemini_api_key_here

# Google Custom Search API Key
# Get your API key from: https://developers.google.com/custom-search/v1/introduction
# Also need to create a Custom Search Engine ID at: https://programmablesearchengine.google.com/
SEARCH_API_KEY=your_search_api_key_here
SEARCH_ENGINE_ID=your_search_engine_id_here

# Database Configuration
# Path to the SQLite database file (relative to app documents directory)
DB_PATH=codium.db

# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Get your Gemini API key from Google AI Studio (https://makersuite.google.com/app/apikey)
# 3. Get your Custom Search API key from Google Cloud Console
# 4. Create a Custom Search Engine at https://programmablesearchengine.google.com/ and get the Engine ID
# 5. Fill in the values above in your .env file
# 6. Run: fvm flutter pub run build_runner build --delete-conflicting-outputs
# 7. Never commit your .env file to version control!

# Security Notes:
# - The API keys will be obfuscated in the compiled binary using envied
# - All API requests use HTTPS for secure communication
# - Keep your .env file private and never commit it to version control
# - The .env file is already listed in .gitignore
